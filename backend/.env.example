# Server
PORT=5000

# MySQL Database
DB_HOST=localhost
DB_PORT=3306
DB_NAME=hospital_queue_db
DB_USER=root
DB_PASS=your_mysql_password

# App
NODE_ENV=production

# IMPORTANT: generate a long random string for this — do NOT reuse the example below.
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=replace_with_a_long_random_secret

# Optional: fix the default admin account created on first run.
# If left unset, a random password is generated and printed to the console once
# (check your Render/host logs for it).
DEFAULT_ADMIN_EMAIL=admin@hospital.com
DEFAULT_ADMIN_PASSWORD=

# ---------------------------------------------------------------------------
# DEPLOYMENT NOTE (Render / Railway / any Node host):
# Set all of the above as Environment Variables in your host's dashboard —
# never upload this .env file itself. Use a managed MySQL add-on (e.g.
# PlanetScale, Railway MySQL, or your host's MySQL service) and point
# DB_HOST/DB_PORT/DB_NAME/DB_USER/DB_PASS at that instance's credentials.
# ---------------------------------------------------------------------------
